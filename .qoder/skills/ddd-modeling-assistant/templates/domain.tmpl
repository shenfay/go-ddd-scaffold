// Package aggregate contains the aggregate root definitions for {{.ModuleName}}
package aggregate

import (
	"fmt"
	"time"
	
	"{{.ProjectModule}}/internal/domain/{{.ModuleName}}/entity"
	"{{.ProjectModule}}/internal/domain/{{.ModuleName}}/event"
)

// {{.AggregateName}}Aggregate represents the {{.ModuleName}} aggregate root
type {{.AggregateName}}Aggregate struct {
	id          string
	createdAt   time.Time
	updatedAt   time.Time
	version     int
	entities    []*entity.{{.EntityName}}
	domainEvents []event.DomainEvent
}

// New{{.AggregateName}}Aggregate creates a new {{.ModuleName}} aggregate
func New{{.AggregateName}}Aggregate(id string) (*{{.AggregateName}}Aggregate, error) {
	if id == "" {
		return nil, fmt.Errorf("aggregate id cannot be empty")
	}
	
	aggregate := &{{.AggregateName}}Aggregate{
		id:        id,
		createdAt: time.Now(),
		updatedAt: time.Now(),
		version:   1,
		entities:  make([]*entity.{{.EntityName}}, 0),
	}
	
	// Publish creation event
	aggregate.domainEvents = append(aggregate.domainEvents, 
		event.New{{.AggregateName}}CreatedEvent(id))
	
	return aggregate, nil
}

// ID returns the aggregate root identifier
func (a *{{.AggregateName}}Aggregate) ID() string {
	return a.id
}

// Version returns the aggregate version
func (a *{{.AggregateName}}Aggregate) Version() int {
	return a.version
}

// CreatedAt returns the creation time
func (a *{{.AggregateName}}Aggregate) CreatedAt() time.Time {
	return a.createdAt
}

// UpdatedAt returns the last update time
func (a *{{.AggregateName}}Aggregate) UpdatedAt() time.Time {
	return a.updatedAt
}

// GetEntities returns all entities in this aggregate
func (a *{{.AggregateName}}Aggregate) GetEntities() []*entity.{{.EntityName}} {
	return a.entities
}

// GetDomainEvents returns unpublished domain events
func (a *{{.AggregateName}}Aggregate) GetDomainEvents() []event.DomainEvent {
	return a.domainEvents
}

// ClearDomainEvents clears published domain events
func (a *{{.AggregateName}}Aggregate) ClearDomainEvents() {
	a.domainEvents = make([]event.DomainEvent, 0)
}

// String implements Stringer interface
func (a *{{.AggregateName}}Aggregate) String() string {
	return fmt.Sprintf("{{.AggregateName}}Aggregate{id: %s, version: %d}", a.id, a.version)
}

// Validate performs aggregate validation
func (a *{{.AggregateName}}Aggregate) Validate() error {
	if a.id == "" {
		return fmt.Errorf("aggregate id is required")
	}
	
	if a.createdAt.IsZero() {
		return fmt.Errorf("creation time is required")
	}
	
	if a.version <= 0 {
		return fmt.Errorf("version must be positive")
	}
	
	return nil
}