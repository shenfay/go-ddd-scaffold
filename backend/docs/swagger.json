                            "$ref": "#/definitions/go-ddd-scaffold_internal_application_user_dto.CreateTenantRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "创建成功的租户信息",
                        "schema": {
                            "$ref": "#/definitions/go-ddd-scaffold_internal_pkg_response.Response"
                        }
                    },
                    "400": {
                        "description": "请求参数错误",
                        "schema": {
                            "$ref": "#/definitions/go-ddd-scaffold_internal_pkg_response.Response"
                        }
                    },
                    "500": {
                        "description": "服务器内部错误",
                        "schema": {
                            "$ref": "#/definitions/go-ddd-scaffold_internal_pkg_response.Response"
                        }
                    }
                }
            }
        },
        "/api/tenants/my-tenants": {
            "get": {
                "description": "获取当前登录用户所属的所有租户及其角色",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "tenants"
                ],
                "summary": "获取用户的租户列表",
                "responses": {
                    "200": {
                        "description": "租户列表",
                        "schema": {
                            "$ref": "#/definitions/go-ddd-scaffold_internal_pkg_response.Response"
                        }
                    },
                    "500": {
                        "description": "服务器内部错误",
                        "schema": {
                            "$ref": "#/definitions/go-ddd-scaffold_internal_pkg_response.Response"
