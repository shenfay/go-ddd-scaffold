# Secrets 配置示例

# Docker Hub 登录信息
DOCKER_USERNAME=your-docker-username
DOCKER_PASSWORD=your-docker-password-or-access-token

# Kubernetes 配置（Base64 编码）
KUBE_CONFIG_STAGING=base64-encoded-kubeconfig

# 数据库配置（用于 CI/CD测试环境）
DB_HOST_TEST=localhost
DB_PORT_TEST=3306
DB_USER_TEST=root
DB_PASSWORD_TEST=test_password
DB_NAME_TEST=go_ddd_scaffold_test

# JWT 密钥（测试环境）
JWT_SECRET_TEST=test-jwt-secret-key-for-ci-cd-pipeline-only
