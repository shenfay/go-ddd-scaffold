        "/api/users/profile": {
            "put": {
                "description": "更新登录用户的个人资料（昵称、手机、简介）",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "users"
                ],
                "summary": "更新个人资料",
                "parameters": [
                    {
                        "description": "个人资料信息",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/go-ddd-scaffold_internal_application_user_dto.UpdateProfileRequest"
