          "datasource": {
            "type": "prometheus",
            "uid": "dfigzsmbru2o0f"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
