{
    "swagger": "2.0",
    "info": {
        "description": "DDD 架构脚手架项目 API文档\n\n## 认证模块\n- POST /api/auth/register 用户注册\n- POST /api/auth/login 用户登录\n- POST /api/auth/logout 用户登出\n\n## 用户管理\n- GET /api/users/:id 获取用户信息\n- PUT /api/users/:id 更新用户信息\n\n## 个人资料\n- GET /api/users/info 获取当前用户信息\n- PUT /api/users/profile 更新个人资料\n\n## 租户管理\n- POST /api/tenants 创建租户\n- GET /api/tenants/my-tenants 获取用户的租户列表\n",
        "title": "go-ddd-scaffold API",
        "contact": {},
        "version": "1.0"
    },
    "paths": {
        "/api/tenants": {
            "post": {
                "description": "创建新的租户，创建者自动成为 owner",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "tenants"
                ],
                "summary": "创建租户",
                "parameters": [
                    {
                        "description": "租户信息",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/go-ddd-scaffold_internal_application_tenant_dto.CreateTenantRequest"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "创建成功",
                        "schema": {
                            "$ref": "#/definitions/go-ddd-scaffold_internal_pkg_response.Response"
                        }
                    },
                    "400": {
                        "description": "请求参数错误",
                        "schema": {
                            "$ref": "#/definitions/go-ddd-scaffold_internal_pkg_response.Response"
                        }
                    },
                    "500": {
                        "description": "服务器内部错误",
                        "schema": {
                            "$ref": "#/definitions/go-ddd-scaffold_internal_pkg_response.Response"
                        }
                    }
                }
            }
        },
        "/api/tenants/my-tenants": {
            "get": {
                "description": "获取当前登录用户所属的所有租户及其角色",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "tenants"
                ],
                "summary": "获取用户的租户列表",
                "responses": {
                    "200": {
                        "description": "租户列表",
                        "schema": {
                            "$ref": "#/definitions/go-ddd-scaffold_internal_pkg_response.Response"
                        }
                    },
                    "500": {
                        "description": "服务器内部错误",
                        "schema": {
                            "$ref": "#/definitions/go-ddd-scaffold_internal_pkg_response.Response"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "go-ddd-scaffold_internal_application_tenant_dto.CreateTenantRequest": {
            "type": "object",
            "required": [
                "maxMembers",
                "name"
            ],
            "properties": {
                "description": {
                    "type": "string",
                    "maxLength": 500
                },
                "maxMembers": {
                    "type": "integer",
                    "minimum": 1
                },
                "name": {
                    "type": "string",
                    "maxLength": 100
                }
            }
        },
        "go-ddd-scaffold_internal_application_user_dto.LoginRequest": {
            "type": "object",
            "required": [
                "email",
                "password"
            ],
            "properties": {
                "email": {
                    "type": "string"
                },
                "password": {
                    "type": "string"
                }
            }
        },
        "go-ddd-scaffold_internal_application_user_dto.LoginResponse": {
            "type": "object",
            "properties": {
                "accessToken": {
                    "type": "string"
                },
                "user": {
                    "$ref": "#/definitions/go-ddd-scaffold_internal_application_user_dto.User"
                }
            }
        },
        "go-ddd-scaffold_internal_application_user_dto.RegisterRequest": {
            "type": "object",
            "required": [
                "email",
                "nickname",
                "password"
            ],
            "properties": {
                "email": {
                    "type": "string"
                },
                "nickname": {
                    "type": "string"
                },
                "password": {
                    "type": "string",
                    "minLength": 6
                },
                "role": {
                    "description": "可选，默认为 member",
                    "type": "string",
                    "enum": [
                        "member",
                        "guest"
                    ]
                },
                "tenantId": {
                    "type": "string"
                }
            }
        },
        "go-ddd-scaffold_internal_application_user_dto.UpdateProfileRequest": {
            "type": "object",
            "properties": {
                "bio": {
                    "type": "string"
                },
                "nickname": {
                    "type": "string"
                },
                "phone": {
                    "type": "string"
                }
            }
        },
        "go-ddd-scaffold_internal_application_user_dto.UpdateUserRequest": {
            "type": "object",
            "properties": {
                "email": {
                    "type": "string"
                },
                "password": {
                    "type": "string",
                    "minLength": 6
                },
                "status": {
                    "type": "string",
                    "enum": [
                        "ACTIVE",
                        "INACTIVE",
                        "SUSPENDED"
                    ]
                }
            }
        },
        "go-ddd-scaffold_internal_application_user_dto.User": {
            "type": "object",
            "properties": {
                "avatar": {
                    "type": "string"
                },
                "bio": {
                    "type": "string"
                },
                "createdAt": {
                    "type": "string"
                },
                "email": {
                    "type": "string"
                },
                "id": {
                    "type": "string"
                },
                "nickname": {
                    "type": "string"
                },
                "phone": {
                    "type": "string"
                },
                "role": {
                    "type": "string"
                },
                "status": {
                    "type": "string"
                },
                "tenantId": {
                    "type": "string"
                },
                "updatedAt": {
                    "type": "string"
                }
            }
        },
        "go-ddd-scaffold_internal_pkg_response.ErrorInfo": {
            "type": "object",
            "properties": {
                "code": {
                    "type": "string"
                },
                "details": {},
                "message": {
                    "type": "string"
                }
            }
        },
        "go-ddd-scaffold_internal_pkg_response.Response": {
            "type": "object",
            "properties": {
                "code": {
                    "type": "string"
                },
                "data": {},
                "error": {
                    "$ref": "#/definitions/go-ddd-scaffold_internal_pkg_response.ErrorInfo"
                },
                "message": {
                    "type": "string"
                },
                "requestId": {
                    "type": "string"
                },
                "timestamp": {
                    "type": "string"
                }
            }
        }
    }
}